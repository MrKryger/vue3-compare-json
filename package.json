{
  "name": "vue3-compare-json",
  "version": "0.1.3",
  "description": "Vue 3 component for comparing JSON data with a GitHub-style diff view.",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs",
      "default": "./dist/index.js"
    },
    "./style.css": {
      "import": "./dist/index.css",
      "require": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./dist/style.css": {
      "import": "./dist/index.css",
      "require": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "json",
    "diff",
    "compare",
    "github-style",
    "typescript",
    "component"
  ],
  "author": "MrKryger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrKryger/vue3-compare-json.git"
  },
  "bugs": {
    "url": "https://github.com/MrKryger/vue3-compare-json/issues"
  },
  "homepage": "https://github.com/MrKryger/vue3-compare-json#readme",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
